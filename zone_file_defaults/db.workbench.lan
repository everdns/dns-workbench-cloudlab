$TTL 3600
@   IN  SOA ns1.workbench.lan. admin.workbench.lan. (
            2026010701 ; serial (YYYYMMDDnn)
            3600       ; refresh
            1800       ; retry
            604800     ; expire
            3600 )     ; minimum

    IN  NS  ns1.workbench.lan.
ns1     IN  A 10.10.1.2
010-000-000-001.workbench.lan.  IN  A  10.0.0.1